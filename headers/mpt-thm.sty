\ProvidesPackage{mpt-thm}[2026/05/07 v3 Theorem-like environments and Helper Commands]

\RequirePackage{amsthm}

%------------------------------------------------------------
% SWITCH BETWEEN SECTION-TYPE AND CHAPTER-TYPE STYLES
%------------------------------------------------------------
\def\cnt@none{none}
\def\cnt@name{section} % default
\DeclareOption{section}{\def\cnt@name{section}}
\DeclareOption{chapter}{\def\cnt@name{chapter}}
\DeclareOption{none}{\def\cnt@name{none}}
\DeclareOption*{\OptionNotUsed}
\ProcessOptions\relax

%------------------------------------------------------------
% ADDITIONAL THEOREM STYLES
%------------------------------------------------------------
% custom style with line-break
\newtheoremstyle{plain-break}
  {}{}%
  {\itshape}{}%
  {\bfseries}{.}%
  {\newline}{}

\newtheoremstyle{definition-break}
  {}{}%
  {\normalfont}{}%
  {\bfseries}{.}%
  {\newline}{}

%------------------------------------------------------------
% BASE ENVIRONMENTS FOR COUNTERS
%------------------------------------------------------------
\ifx\cnt@name\cnt@none
  \theoremstyle{plain}
  \newtheorem{nthm}{Theorem}
  \theoremstyle{definition}
  \newtheorem{nex}{Exercise}
\else
  \theoremstyle{plain}
  \newtheorem{nthm}{Theorem}[\cnt@name]
  \theoremstyle{definition}
  \newtheorem{nex}{Exercise}[\cnt@name]
\fi

%------------------------------------------------------------
% THEOREM-LIKE
%------------------------------------------------------------
\theoremstyle{plain}

\newtheorem{nprop}[nthm]{Proposition}
\newtheorem{nlemma}[nthm]{Lemma}
\newtheorem{ncor}[nthm]{Corollary}
\newtheorem{nclaim}[nthm]{Claim}
\newtheorem{nconjecture}[nthm]{Conjecture}

\newtheorem*{thm}{Theorem}
\newtheorem*{prop}{Proposition}
\newtheorem*{lemma}{Lemma}
\newtheorem*{cor}{Corollary}
\newtheorem*{claim}{Claim}
\newtheorem*{conjecture}{Conjecture}

\theoremstyle{plain-break}

\newtheorem*{bthm}{Theorem}
\newtheorem*{bprop}{Proposition}
\newtheorem*{blemma}{Lemma}
\newtheorem*{bcor}{Corollary}
\newtheorem*{bclaim}{Claim}
\newtheorem*{bconjecture}{Conjecture}

\newtheorem{nbthm}[nthm]{Theorem}
\newtheorem{nbprop}[nthm]{Proposition}
\newtheorem{nblemma}[nthm]{Lemma}
\newtheorem{nbcor}[nthm]{Corollary}
\newtheorem{nbclaim}[nthm]{Claim}
\newtheorem{nbconjecture}[nthm]{Conjecture}

%------------------------------------------------------------
% DEFINITION-LIKE
%------------------------------------------------------------
\theoremstyle{definition}

\newtheorem{ndfn}[nthm]{Definition}
\newtheorem{negg}[nthm]{Example}
\newtheorem{nremark}[nthm]{Remark}

\newtheorem*{dfn}{Definition}
\newtheorem*{egg}{Example}
\newtheorem*{remark}{Remark}

\theoremstyle{definition-break}

\newtheorem{nbdfn}[nthm]{Definition}
\newtheorem{nbegg}[nthm]{Example}
\newtheorem{nbremark}[nthm]{Remark}

\newtheorem*{bdfn}{Definition}
\newtheorem*{begg}{Example}
\newtheorem*{bremark}{Remark}

%------------------------------------------------------------
% EXERCISE-LIKE
%------------------------------------------------------------
\theoremstyle{definition}

\newtheorem{nexercise}[nex]{Exercise}

\newtheorem*{ex}{Exercise}
\newtheorem*{exercise}{Exercise}

\theoremstyle{definition-break}

\newtheorem*{bex}{Exercise}
\newtheorem*{bexercise}{Exercise}

\newtheorem{nbex}[nex]{Exercise}
\newtheorem{nbexercise}[nex]{Exercise}

%------------------------------------------------------------
% ENVIRONEMNTS WITH INDEPENDENT/NO COUNTERS
%------------------------------------------------------------
\theoremstyle{definition}

\newtheorem{naxiom}{Axiom}
\newtheorem{nlaw}{Law}
\newtheorem{nnotation}{Notation}
\newtheorem{nprinciple}{Principle}
\newtheorem{nwarning}{Warning}

\newtheorem*{axiom}{Axiom}
\newtheorem*{law}{Law}
\newtheorem*{notation}{Notation}
\newtheorem*{principle}{Principle}
\newtheorem*{warning}{Warning}

\theoremstyle{definition-break}

\newtheorem{nbaxiom}{Axiom}
\newtheorem{nblaw}{Law}
\newtheorem{nbnotation}{Notation}
\newtheorem{nbprinciple}{Principle}
\newtheorem{nbwarning}{Warning}

\newtheorem*{baxiom}{Axiom}
\newtheorem*{blaw}{Law}
\newtheorem*{bnotation}{Notation}
\newtheorem*{bprinciple}{Principle}
\newtheorem*{bwarning}{Warning}

%------------------------------------------------------------
% END OF PROOF: QED SYMBOLS
%------------------------------------------------------------
% \renewcommand\qedsymbol{Bob's Your Uncle.}

\newcommand{\qedegg}{\begingroup\pushQED{\qed}\qedhere\endgroup}
\newcommand{\qedblack}{\begingroup\renewcommand\qedsymbol{$\blacksquare$}\pushQED{\qed}\qedhere\endgroup}
\newcommand{\qeddiamond}{\begingroup\renewcommand\qedsymbol{$\diamond$}\pushQED{\qed}\qedhere\endgroup}
\newcommand{\qedtriangle}{\begingroup\renewcommand\qedsymbol{$\triangle$}\pushQED{\qed}\qedhere\endgroup}
\newcommand{\qedbar}{\begingroup\renewcommand\qedsymbol{\rule[-0.2pt]{2pt}{\fontcharht\font`I}}\pushQED{\qed}\qedhere\endgroup}
\newcommand{\qedbb}{\begingroup\renewcommand\qedsymbol{//}\pushQED{\qed}\qedhere\endgroup}

\let\eggqed\qedegg % For compatibility (to be removed)

%------------------------------------------------------------
% SPECIAL CMDS & ENVS FOR QUESTION-SOLUTION TYPESETTING
%------------------------------------------------------------
\newcommand{\questlabel}{Question}
\let\questlabelbreak\relax
\NewDocumentEnvironment{quest}{o}{\IfNoValueTF{#1}{{\bfseries\questlabel.}}{{\bfseries\questlabel\ {#1}.}}\questlabelbreak}{}

\NewDocumentCommand{\score}{omo}{\hfill{\bfseries[\IfNoValueF{#1}{#1 }#2\IfNoValueF{#3}{ #3}]}}
\NewDocumentCommand{\hint}{O{Hint}m}{{\itshape(#1: #2)}}
