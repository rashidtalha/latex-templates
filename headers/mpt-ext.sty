\ProvidesPackage{mpt-ext}[2026/05/07 v3 Extension to mpt-core for MathsPhysicsTools]

% Extension of mpt-core.sty.
% Strongly advised that mpt-core is also loaded
\RequirePackage{mathtools}
\RequirePackage{amssymb}
\RequirePackage{esint}

\RequirePackage{siunitx}
\RequirePackage{tensor}
\RequirePackage{slashed}

\sisetup{separate-uncertainty=true}

%------------------------------------------------------------
% PROBABILITY, STATISTICS
%------------------------------------------------------------
% Probability and statistics
\newcommand{\pP}{\mathbf{P}}
\newcommand{\pE}{\mathbf{E}}
\newcommand{\pVar}{\mathbf{Var}}
\newcommand{\pCov}{\mathbf{Cov}}

%------------------------------------------------------------
% ANALYSIS
%------------------------------------------------------------
% Weak and weak-star convergence
\newcommand{\wconv}{\mathrel{\rightharpoonup}}
\newcommand{\wsconv}{\mathrel{\overset{\ast}{\rightharpoonup}}}

% Transforms
\DeclareMathOperator{\FT}{\operatorname{\mathcal{F}}}
\DeclareMathOperator{\LT}{\operatorname{\mathcal{L}}}
\DeclareMathOperator{\MT}{\operatorname{\mathcal{M}}}

%------------------------------------------------------------
% CLASSICAL PHYSICS, QUANTUM MECHANICS
%------------------------------------------------------------
% Quantum Mechanics
\DeclarePairedDelimiter{\comm}{\lbrack}{\rbrack}
\DeclarePairedDelimiter{\acomm}{\lbrace}{\rbrace}

% Dirac brackets
\DeclarePairedDelimiterX{\bra}[1]{\langle}{\rvert}{#1}
\DeclarePairedDelimiterX{\ket}[1]{\lvert}{\rangle}{#1}
\DeclarePairedDelimiterX{\braket}[2]{\langle}{\rangle}{#1\,\delimsize\vert\,#2}
\DeclarePairedDelimiterX{\matrixel}[3]{\langle}{\rangle}{#1\,\delimsize\vert\, #2 \,\delimsize\vert\,#3}

% Slashed operators
\newcommand{\pds}{\slashed{\partial}}
\newcommand{\Ds}{\slashed{D}}

% Other
\DeclarePairedDelimiterXPP{\nord}[1]{N}{\lbrace}{\rbrace}{}{#1}
\DeclarePairedDelimiterXPP{\tord}[1]{T}{\lbrace}{\rbrace}{}{#1}
