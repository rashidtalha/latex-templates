%%%%%%%%%%%%% LISTS
\setbeamercolor{itemize item}{fg=structure.fg!90}
\setbeamercolor{itemize subitem}{fg=structure.fg!70}
\setbeamercolor{itemize subsubitem}{fg=structure.fg!70}
\setbeamercolor{enumerate item}{fg=structure.fg}
\setbeamercolor{enumerate subitem}{fg=structure.fg!90}
\setbeamercolor{enumerate subsubitem}{fg=structure.fg!80}

\setbeamertemplate{itemize item}{\raisebox{0.35ex}{\footnotesize$\blacktriangleright$}}
\setbeamertemplate{itemize subitem}{\raisebox{0.15ex}{\small\textendash}}
\setbeamertemplate{itemize subsubitem}{\raisebox{0.15ex}{\small\textasteriskcentered}}

\setbeamertemplate{enumerate item}{\arabic{enumi}.}
\setbeamertemplate{enumerate subitem}{(\alph{enumii})}
\setbeamertemplate{enumerate subsubitem}{\roman{enumiii}.}

%%%%%%%%%%%%% BIBLIOGRAPHY / REFERENCES
\setbeamertemplate{bibliography item}[text]

\setbeamercolor{bibliography item}{fg=Primary}
\setbeamercolor{bibliography entry author}{fg=normal text.fg}
\setbeamercolor{bibliography entry title}{fg=normal text.fg}
\setbeamercolor{bibliography entry location}{fg=normal text.fg!70}
\setbeamercolor{bibliography entry note}{fg=normal text.fg!60}

\setbeamerfont{bibliography item}{size=\small}
\setbeamerfont{bibliography entry author}{size=\small}
\setbeamerfont{bibliography entry title}{size=\small}
\setbeamerfont{bibliography entry location}{size=\small}
\setbeamerfont{bibliography entry note}{size=\small}

\setbeamertemplate{bibliography entry article}{}
\setbeamertemplate{bibliography entry title}{}
\setbeamertemplate{bibliography entry location}{}
\setbeamertemplate{bibliography entry note}{}

%%%%%%%%%%%%% OTHER SETTINGS
\setbeamercovered{transparent}
\setbeamertemplate{section in toc}[square]

%%%%%%%%%%%%% AUXILIARY
\newcommand{\umaketitle}{
\begin{beamercolorbox}[wd=0.9\paperwidth,sep=9pt,center]{title}
    {\usebeamerfont{title}\inserttitle}\par
    \ifx\insertsubtitle\@empty\else
    \vspace{1.5ex}
    {\usebeamerfont{subtitle}\insertsubtitle}
    \fi
\end{beamercolorbox}}

%%%%%%%%%%%%% FOOTLINE
\beamertemplatenavigationsymbolsempty

\newcommand{\ufootlineL}{}
\newcommand{\ufootlinecontent}{\ufootlineL\hfill\insertframenumber\space/\space\inserttotalframenumber}

\setbeamerfont{footline}{size=\scriptsize}
\setbeamercolor{footline}{bg=, fg=normal text.fg}

\setbeamertemplate{footline}{%
    \leavevmode%
    \begin{beamercolorbox}[wd=\paperwidth, ht=3ex, dp=1.25ex, leftskip=2ex, rightskip=2ex]{footline}%
        \usebeamerfont{footline}\ufootlinecontent%
    \end{beamercolorbox}%
    \vskip0pt%
}

%%%%%%%%%%%%% CUSTOM FOOTNOTES (from penrose.cls)
\renewcommand{\@makefntext}[1]{%
  \setlength{\parindent}{1.5em}\parskip\z@%
  \let\nextpar\relax%
  \everypar{%
    \hangindent=1.5em\hangafter=1\nextpar%
    \gdef\nextpar{\hspace{\parindent}}%
  }%
  \noindent\hb@xt@1.5em{\hss\@makefnmark\,}#1
}

\newcommand{\ufootnote}[2][]{
  \begingroup
    \renewcommand\thefootnote{}%
    \def\@makefnmark{$^{#1}$}%
    \let\Hy@raisedlink\@gobble%
    \let\hyper@anchorstart\@gobble%
    \let\hyper@anchorend\@gobble%
    \footnotetext{#2}%
  \endgroup
}

\mode<all>