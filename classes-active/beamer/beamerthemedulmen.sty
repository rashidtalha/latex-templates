%%%%%%%%%%%%% FONT-COLOUR SETTINGS AND NORMALISATION
\setbeamercolor{normal text}{fg=uBlack, bg=uWhite}
\setbeamercolor{structure}{fg=Primary, bg=normal text.bg}

\setbeamercolor{background canvas}{bg=normal text.bg}

\setbeamerfont{title}{size=\Large}
\setbeamercolor{title}{bg=uWhite, fg=structure.fg}

\setbeamercolor{frametitle}{bg=uWhite, fg=structure.fg}
\setbeamerfont{framesubtitle}{size=\normalsize}

\setbeamercolor{block title}{fg=structure.fg, bg=uWhite}
\setbeamercolor{block body}{bg=uWhite}

\setbeamercolor{alerted text}{fg=Red}
\setbeamercolor{block title alerted}{fg=Red, bg=uWhite}
\setbeamercolor{block body alerted}{bg=uWhite}

%% OTHER THEME (incomplete):

